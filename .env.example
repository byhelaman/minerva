# ==============================================
# 🌍 CONFIGURACIÓN PÚBLICA (FRONTEND / TAURI)
# ==============================================

# URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Clave pública anónima (Anon Key) - Seguro de exponer en el frontend
VITE_SUPABASE_ANON_KEY=

# La configuración del asistente IA se gestiona desde la app: Configuración → Asistente.

# ==============================================
# 🔐 SECRETOS DE BACKEND (SUPABASE EDGE FUNCTIONS)
# ==============================================
# ⚠️ ADVERTENCIA: Estos valores NO se usan en la app Tauri/Frontend.
# Deben configurarse en: Supabase Dashboard -> Settings -> Edge Functions -> Secrets.
# Se mantienen aquí SOLO como referencia para desarrollo local o scripts de deploy.

# Credenciales de Zoom (General App / Server-to-Server)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
ZOOM_REDIRECT_URI=https://[PROJECT_REF].supabase.co/functions/v1/zoom-auth/callback
ZOOM_WHITELIST_EMAILS="email1@example.com, email2@example.com"

# Clave maestra interna para comunicación protegida (ej: pg_cron -> Edge Function)
INTERNAL_API_KEY=

# Credenciales de Microsoft (Azure AD App Registration)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://[PROJECT_REF].supabase.co/functions/v1/microsoft-auth/callback

# Firma de actualizaciones Tauri (generada con `pnpm tauri signer generate`)
TAURI_SIGNING_PRIVATE_KEY=